# Profile: wsl2-4070ti
#
# RTX 4070 Ti SUPER 16GB (Ada Lovelace, sm_89) under WSL2 on Windows. Ada
# Lovelace has FP8 tensor cores, so this profile serves a pre-quantized FP8
# checkpoint per spec 02a-workloads.md section 5 ("Serve FP8 weights (about
# 7.6 GB) with fp16 KV cache"): weights are FP8, the KV cache itself stays in
# the model's default compute dtype (no --kv-cache-dtype override), matching
# the spec's KV math (57KB/token for Qwen2.5-7B) exactly.
#
# EVOKE_MODEL is RedHatAI/Qwen2.5-7B-Instruct-FP8-dynamic (Neural Magic /
# Red Hat AI, apache-2.0, verified on huggingface.co 2026-07-11): weights and
# activations quantized FP8 via llm-compressor, vLLM auto-detects the
# compressed-tensors quantization config from the checkpoint, so
# EVOKE_QUANTIZATION is left empty. Set it explicitly only if auto-detection
# ever fails on a future vLLM release.
#
# Sourced by scripts/serve.sh via --profile wsl2-4070ti. See
# profiles/local-2060.env's header for why the EVOKE_W_* names below must
# stay exactly as evoke_vllm.config.EvokeScoringConfig.apply_env_overrides
# expects them.

EVOKE_MODEL="RedHatAI/Qwen2.5-7B-Instruct-FP8-dynamic"
EVOKE_SERVED_MODEL_NAME="qwen2.5-7b-instruct-fp8"
EVOKE_HOST="0.0.0.0"
EVOKE_PORT="8000"
EVOKE_DTYPE="auto"
EVOKE_MAX_MODEL_LEN="16384"
EVOKE_QUANTIZATION=""

EVOKE_BLOCK_SIZE="16"

# VALIDATED ON THE REAL CARD 2026-07-11 (RTX 4070 Ti SUPER 16GB, WSL2).
# 0.55 cannot boot: weights + CUDA graphs + activations at max_model_len
# 16384 consume about 9,640 MiB before any KV, and 0.55 x 16,376 MiB
# leaves nothing ("No available memory for the cache blocks"). 0.65 yields
# a ~17,280-token pool, which holds about 1.4 of the benchmark's 12k-token
# contexts, so W1/W2's round-robin working set (8 x 12k = 96k tokens,
# ~5.6x overcommit) must spill to the offload tier on every revisit. The
# first matrix run used 0.68 (26,256-token pool) and was vacuous: eviction
# never triggered, every budget produced byte-identical numbers. Two
# observed hazards: the pool shrinks by up to ~9k tokens if the server
# launches while a previous server's VRAM is still releasing, so wait for
# nvidia-smi memory.used to drop below ~1.2GB between launches; and the
# fidelity gate needs an asymmetric override (see scripts/README_GATES.md):
# baseline arm at 0.85 so the reference never evicts.
EVOKE_GPU_MEMORY_UTILIZATION="0.65"

# CPU offload tier size in bytes. WSL2 caps total VM memory at 50% of
# Windows RAM by default (.wslconfig [wsl2] memory=), so this must fit
# inside whatever that box's .wslconfig allows, not just "spare RAM"; see
# scripts/README_GATES.md for the WSL2 memory-limit setup step. 8GiB assumes
# a .wslconfig memory limit of at least 16GB; lower it if the box is smaller.
EVOKE_CPU_BYTES_TO_USE="8589934592"

EVOKE_OFFLOAD_BLOCK_SIZE="64"

# Store on first offer. The product default is 2 (a block is stored only
# on its second computation), but under benchmark pressure stores then lag
# eviction and the run comes back vacuous (observed twice on the real
# card: the gate at 69.7MB stored / zero restored, then the whole first
# matrix at 3.7MB stored / zero hits). Both the stock CPU offload spec
# (vllm/v1/kv_offload/cpu/spec.py, arm A1) and EvokeOffloadingSpec (arm
# A2) read this key, so arm parity holds.
EVOKE_STORE_THRESHOLD="1"

EVOKE_W_RECENCY="0.5"
EVOKE_W_REUSE="0.5"
EVOKE_RECENCY_HALF_LIFE="64"
