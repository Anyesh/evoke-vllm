# Profile: local-2060
#
# RTX 2060 6GB (Turing, sm_75). No FP8 tensor cores on this GPU, so the model
# stays fp16. gpu_memory_utilization is set low on purpose: the correctness
# gate needs the GPU prefix cache to evict under the multi-session workload
# in scripts/fidelity_gate.py, so blocks land in the CPU offload tier and a
# later replay has something real to restore from.
#
# Sourced by scripts/serve.sh via --profile local-2060. Every EVOKE_* name
# here is read directly by serve.sh; the four scoring knobs
# (EVOKE_W_RECENCY, EVOKE_W_REUSE, EVOKE_RECENCY_HALF_LIFE) intentionally
# reuse the exact env-var names evoke_vllm.config.EvokeScoringConfig.
# apply_env_overrides already reads inside the served process, because
# apply_env_overrides always wins over the JSON kv_connector_extra_config
# serve.sh also embeds them into, so sourcing this file once keeps both
# paths consistent instead of maintaining the same numbers twice under
# different names.

EVOKE_MODEL="Qwen/Qwen2.5-1.5B-Instruct"
EVOKE_SERVED_MODEL_NAME="qwen2.5-1.5b-instruct"
EVOKE_HOST="0.0.0.0"
EVOKE_PORT="8000"
EVOKE_DTYPE="float16"
EVOKE_MAX_MODEL_LEN="4096"
EVOKE_QUANTIZATION=""

# Engine KV block size, in tokens (vllm serve --block-size). Pinned explicitly
# rather than left on vLLM's auto default so EVOKE_OFFLOAD_BLOCK_SIZE below
# has a known value to be a multiple of.
EVOKE_BLOCK_SIZE="16"

# VALIDATED ON THE REAL CARD 2026-07-11: 0.75 yields a 7,840-token GPU KV
# pool (0.21 GiB) and passed the fidelity gate non-vacuously with the
# 10-session x 6-growth-turn workload (about 18k tokens of session
# footprint, 2.3x overcommit). The original 0.60 starting point cannot even
# boot on this card (weights + CUDA graphs + activations need about 4.4 GiB
# before any KV), and 0.85 gives a 28,832-token pool the gate workload
# never evicts from, so the gate passes vacuously. If restores never fire
# during fidelity_gate.py, grow the workload before touching this value.
# Watch the "GPU KV cache size" line vLLM prints at startup and the
# vllm:kv_cache_usage_perc gauge while tuning.
EVOKE_GPU_MEMORY_UTILIZATION="0.75"

# CPU offload tier size in bytes (kv_connector_extra_config.cpu_bytes_to_use).
# Kept generous relative to the fidelity_gate.py workload's footprint on
# purpose: the gate isolates "GPU evicts, CPU restores" behavior, not
# EVOKE's eviction ordering under CPU pressure too (that is already covered
# by the offline policy unit tests in tests/test_policy.py). 4GiB assumes a
# normal dev machine has that much spare host RAM free; lower it if not.
EVOKE_CPU_BYTES_TO_USE="4294967296"

# kv_connector_extra_config.block_size: offload granularity in tokens. Must
# be a multiple of EVOKE_BLOCK_SIZE (vllm/v1/kv_offload/base.py asserts this
# at spec construction time); serve.sh checks it before exec so a bad value
# fails in milliseconds instead of after a multi-minute model load.
EVOKE_OFFLOAD_BLOCK_SIZE="64"

EVOKE_STORE_THRESHOLD="2"

EVOKE_W_RECENCY="0.5"
EVOKE_W_REUSE="0.5"
EVOKE_RECENCY_HALF_LIFE="64"
